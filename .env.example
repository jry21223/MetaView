APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
APT_SECURITY_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian-security
APT_PIPELINE_DEPTH=0

ALGO_VIS_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
ALGO_VIS_DEFAULT_PROVIDER=
ALGO_VIS_DEFAULT_ROUTER_PROVIDER=
ALGO_VIS_DEFAULT_GENERATION_PROVIDER=
ALGO_VIS_MOCK_PROVIDER_ENABLED=true
ALGO_VIS_SANDBOX_TIMEOUT_MS=1500
ALGO_VIS_MAX_REPAIR_ATTEMPTS=2
ALGO_VIS_HISTORY_DB_PATH=data/pipeline_runs.db
ALGO_VIS_PREVIEW_RENDER_BACKEND=auto
ALGO_VIS_MANIM_PYTHON_PATH=.venv-manim/bin/python
ALGO_VIS_CJK_FONT_FAMILY=Noto Sans CJK SC
ALGO_VIS_CJK_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
ALGO_VIS_PREVIEW_TTS_ENABLED=true
ALGO_VIS_PREVIEW_TTS_BACKEND=openai_compatible
ALGO_VIS_PREVIEW_TTS_MODEL=mimotts-v2
ALGO_VIS_PREVIEW_TTS_BASE_URL=
ALGO_VIS_PREVIEW_TTS_API_KEY=
ALGO_VIS_PREVIEW_TTS_VOICE=default
ALGO_VIS_PREVIEW_TTS_RATE_WPM=150
ALGO_VIS_PREVIEW_TTS_SPEED=0.88
ALGO_VIS_PREVIEW_TTS_MAX_CHARS=1500
ALGO_VIS_PREVIEW_TTS_TIMEOUT_S=120.0

# Configure these to enable the OpenAI-compatible provider.
ALGO_VIS_OPENAI_API_KEY=
ALGO_VIS_OPENAI_BASE_URL=https://api.openai.com/v1
ALGO_VIS_OPENAI_MODEL=
ALGO_VIS_OPENAI_SUPPORTS_VISION=false
ALGO_VIS_OPENAI_TIMEOUT_S=

# Optional for production-like static deployment.
VITE_API_BASE_URL=
